DEBUG=True
# En local (DEBUG=True) la valeur ci-dessous suffit. En production (DEBUG=False),
# le démarrage refuse toute valeur de moins de 32 caractères ou égale à ce
# placeholder — générer une vraie clé avec :
# docker compose exec backend python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

DB_NAME=anifowoche
DB_USER=anifowoche
DB_PASSWORD=changeme
# DB_HOST=db        -> via docker compose (nom du service)
# DB_HOST=localhost -> backend lancé hors conteneur
DB_HOST=db
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

FRONTEND_BASE_URL=http://localhost:5173

# Cloudinary (stockage des images produits/bannières) — https://cloudinary.com/console
# Laisser vide pour garder le stockage disque local (dev). Renseigner en prod.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# FedaPay (sandbox MTN/Moov + carte) — https://docs.fedapay.com/
# Laisser les valeurs placeholder tant que les vraies clés sandbox ne sont pas fournies.
FEDAPAY_BASE_URL=https://sandbox-api.fedapay.com
FEDAPAY_SECRET_KEY=sk_sandbox_placeholder
FEDAPAY_WEBHOOK_SECRET=whsec_placeholder

# WhatsApp Business Cloud API (Meta) — https://developers.facebook.com/docs/whatsapp/cloud-api/
# Laisser les valeurs placeholder tant que le vrai token et le phone_number_id ne sont pas fournis.
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=000000000000000
WHATSAPP_ACCESS_TOKEN=whatsapp_token_placeholder

# Resend (emails transactionnels : confirmation de compte, facture, livraison) — https://resend.com/docs
# Laisser les valeurs placeholder tant qu'un domaine vérifié et une vraie clé API ne sont pas fournis.
RESEND_API_BASE_URL=https://api.resend.com
RESEND_API_KEY=re_placeholder
RESEND_FROM_EMAIL=ANIFOWOCHE <onboarding@resend.dev>

# ngrok (dev uniquement) — tunnel public vers le backend pour tester les
# webhooks externes (FedaPay...) en local. Laisser vide si non utilisé ;
# obtenir un token gratuit sur https://dashboard.ngrok.com/get-started/your-authtoken
# puis lancer : docker compose exec backend python manage.py start_ngrok
NGROK_AUTHTOKEN=

# Sentry (monitoring erreurs/performance) — https://sentry.io
# Laisser vide en dev : Sentry est totalement inactif sans DSN. Renseigner en
# prod (Render) avec le DSN du projet Sentry « Django ».
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
